﻿@{
    ViewData["Title"] = "MeetDesk - Meet Persons online, Chat, MakeConference";
}

<section class="slider"></section>

<section class="discover"></section>

<section class="solutions">
    
</section>


<section class="ms-plans" aria-label="Plans and add-ons">
   
</section>



<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Take the next step with Teams</title>
</head>
<body>
  <!-- დეკორატიული ფონური სურათები -->
  <img class="bg-left" src="images/bg-left.png" alt="" aria-hidden="true">
  <img class="bg-right" src="images/bg-right.png" alt="" aria-hidden="true">

  <main class="container">
    <p  class="kicker" <b>GET STARTED</b></p>
    <h1 class="headline">
  Take the next step with MeetDesk <span style="color: #0078D7;">MeetDesk</span>
</h1>
        <p class="subhead">
  Whether you're looking for a solution for your business, personal life, or education, 
  <span style="color: #0078D7;">Meet</span>Desk has a plan for you.
</p>

    <section class="cards">
      <!-- Card 1 -->
      <article class="card">
        <div class="card-top">
          <div class="icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="3" width="7" height="7" stroke="#0078D7" stroke-width="1.2" rx="1.2"/>
              <rect x="14" y="3" width="7" height="7" stroke="#0078D7" stroke-width="1.2" rx="1.2"/>
            </svg>
          </div>

          <h2>For business</h2>
          <p>Grow your customer base with communications software designed for up to 300 employees.</p>
        </div>

        <div class="card-bottom">
          <a class="btn" href="#">See plans and pricing</a>
        </div>
      </article>

      <!-- Card 2 -->
      <article class="card">
        <div class="card-top">
          <div class="icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="8" r="2.5" stroke="#0078D7" stroke-width="1.2"/>
              <path d="M5 19c1.8-2.8 4.6-4 7-4s5.2 1.2 7 4" stroke="#0078D7" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </div>

          <h2>For personal use</h2>
          <p>Plan events, share photos, and connect with your friends, family, and community.</p>
        </div>

        <div class="card-bottom">
          <a class="btn" href="#">Try Teams for free</a>
        </div>
      </article>


      <!-- Card 3 -->
      <article class="card">
        <div class="card-top">
          <div class="icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3.5" y="6.5" width="17" height="11" rx="2" stroke="#0078D7" stroke-width="1.2"/>
              <path d="M7 10h1.5M7 13h1.5" stroke="#0078D7" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </div>

          <h2>For enterprise</h2>
          <p>Achieve more with Teams accounts for more than 300 people.</p>
        </div>

        <div class="card-bottom">
          <a class="btn" href="#">Get started</a>
        </div>
      </article>

      <!-- Card 4 -->
      <article class="card">
  <div class="card-top">
    <div class="icon" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- განათლების ლოგო (მაგ: წიგნი) -->
        <path d="M2 6l10 5 10-5-10-5-10 5z" stroke="#0078D7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M2 6v12l10 5 10-5V6" stroke="#0078D7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M12 11v10" stroke="#6B46FF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <h2>For education</h2>
    <p>Make learning collaborative—for both students and educators.</p>
  </div>

  <div class="card-bottom">
    <a class="btn" href="#">Learn more</a>
  </div>
</article>
    </section>
  </main>
</body>
</html>
