-- Drop all Foreign Key constraints first to enable clean table drops
DECLARE @sql NVARCHAR(MAX) = N'';
SELECT @sql += N'ALTER TABLE ' + QUOTENAME(OBJECT_SCHEMA_NAME(parent_object_id))
    + '.' + QUOTENAME(OBJECT_NAME(parent_object_id)) + 
    ' DROP CONSTRAINT ' + QUOTENAME(name) + ';' + CHAR(13) + CHAR(10)
FROM sys.foreign_keys;
EXEC sp_executesql @sql;
GO

-- Drop tables (Order matters less now, but good practice)
IF OBJECT_ID('dbo.SolutionCards', 'U') IS NOT NULL DROP TABLE dbo.SolutionCards;
GO
IF OBJECT_ID('dbo.SolutionSections', 'U') IS NOT NULL DROP TABLE dbo.SolutionSections;
GO

IF OBJECT_ID('dbo.PlansCards', 'U') IS NOT NULL DROP TABLE dbo.PlansCards;
GO
IF OBJECT_ID('dbo.PlansAll', 'U') IS NOT NULL DROP TABLE dbo.PlansAll;
GO
IF OBJECT_ID('dbo.PlansSections', 'U') IS NOT NULL DROP TABLE dbo.PlansSections;
GO

IF OBJECT_ID('dbo.DiscoverCards', 'U') IS NOT NULL DROP TABLE dbo.DiscoverCards;
GO
IF OBJECT_ID('dbo.DiscoverSections', 'U') IS NOT NULL DROP TABLE dbo.DiscoverSections;
GO

IF OBJECT_ID('dbo.Sliders', 'U') IS NOT NULL DROP TABLE dbo.Sliders;
GO

IF OBJECT_ID('dbo.AuthCarts', 'U') IS NOT NULL DROP TABLE dbo.AuthCarts;
GO
IF OBJECT_ID('dbo.MenuItems', 'U') IS NOT NULL DROP TABLE dbo.MenuItems;
GO
IF OBJECT_ID('dbo.MainMenuSections', 'U') IS NOT NULL DROP TABLE dbo.MainMenuSections;
GO

IF OBJECT_ID('dbo.RegisterTexts', 'U') IS NOT NULL DROP TABLE dbo.RegisterTexts;
GO

IF OBJECT_ID('dbo.ResourcesCards', 'U') IS NOT NULL DROP TABLE dbo.ResourcesCards;
GO
IF OBJECT_ID('dbo.ResourcesSections', 'U') IS NOT NULL DROP TABLE dbo.ResourcesSections;
GO

-- Create tables
CREATE TABLE SolutionSections (
    Id INT PRIMARY KEY IDENTITY(1,1),
    SolutionName NVARCHAR(255),
    SolutionDescription NVARCHAR(MAX),
    Language NVARCHAR(10)
);
GO

CREATE TABLE SolutionCards (
    Id INT PRIMARY KEY IDENTITY(1,1),
    SolutionSectionId INT FOREIGN KEY REFERENCES SolutionSections(Id),
    SolutionCardName NVARCHAR(255),
    SolutionCardDescription NVARCHAR(MAX),
    SolutionCardButton NVARCHAR(50),
    SolutionCardSliderImg NVARCHAR(255),
    Language NVARCHAR(10)
);
GO

CREATE TABLE PlansSections (
    Id INT PRIMARY KEY IDENTITY(1,1),
    Language NVARCHAR(10),
    PlansTitle NVARCHAR(255),
    PlansDescription NVARCHAR(MAX)
);
GO

CREATE TABLE PlansAll (
    Id INT PRIMARY KEY IDENTITY(1,1),
    PlansSectionId INT FOREIGN KEY REFERENCES PlansSections(Id),
    Img NVARCHAR(255),
    MenuItem NVARCHAR(50)
);
GO

CREATE TABLE PlansCards (
    Id INT PRIMARY KEY IDENTITY(1,1),
    PlansAllId INT FOREIGN KEY REFERENCES PlansAll(Id),
    Icon NVARCHAR(MAX),
    Title NVARCHAR(255),
    Description NVARCHAR(MAX),
    More NVARCHAR(50)
);
GO

CREATE TABLE DiscoverSections (
    Id INT PRIMARY KEY IDENTITY(1,1),
    DiscoverHeader NVARCHAR(255),
    Language NVARCHAR(10)
);
GO

CREATE TABLE DiscoverCards (
    Id INT PRIMARY KEY IDENTITY(1,1),
    DiscoverSectionId INT FOREIGN KEY REFERENCES DiscoverSections(Id),
    Img NVARCHAR(255),
    DiscoverCardHeader NVARCHAR(255),
    DiscoverCardHeaderDescription NVARCHAR(MAX),
    DiscoverCardButton NVARCHAR(50)
);
GO

CREATE TABLE Sliders (
    Id INT PRIMARY KEY IDENTITY(1,1),
    HeaderText NVARCHAR(MAX),
    ParagraphText NVARCHAR(MAX),
    Img NVARCHAR(255),
    Language NVARCHAR(10),
    SliderButton NVARCHAR(50)
);
GO

-- Main Menu Section
CREATE TABLE MainMenuSections (
    Id INT PRIMARY KEY IDENTITY(1,1),
    Language NVARCHAR(10),
    Download NVARCHAR(100),
    SignIn NVARCHAR(100),
    LangGeo NVARCHAR(10),
    LangENG NVARCHAR(10),
    FooterFirstText NVARCHAR(255)
);
GO

CREATE TABLE AuthCarts (
    Id INT PRIMARY KEY IDENTITY(1,1),
    MainMenuSectionId INT FOREIGN KEY REFERENCES MainMenuSections(Id),
    UsernamePlaceholder NVARCHAR(100),
    PasswordPlaceholder NVARCHAR(100),
    ForgotPassword NVARCHAR(100),
    SignIn NVARCHAR(100),
    GoogleSignIn NVARCHAR(100),
    MsSignIn NVARCHAR(100),
    RegisterPrompt NVARCHAR(100),
    RegisterLink NVARCHAR(100)
);
GO

CREATE TABLE MenuItems (
    Id INT PRIMARY KEY IDENTITY(1,1),
    MainMenuSectionId INT FOREIGN KEY REFERENCES MainMenuSections(Id),
    MenuItemText NVARCHAR(100)
);
GO

-- Register Text Section
CREATE TABLE RegisterTexts (
    Id INT PRIMARY KEY IDENTITY(1,1),
    Language NVARCHAR(10),
    Title NVARCHAR(100),
    FirstName NVARCHAR(100),
    LastName NVARCHAR(100),
    Birthday NVARCHAR(100),
    Gender NVARCHAR(100),
    Female NVARCHAR(100),
    Male NVARCHAR(100),
    Custom NVARCHAR(100),
    PhoneMail NVARCHAR(100),
    Password NVARCHAR(100),
    ConfirmPassword NVARCHAR(100),
    Submit NVARCHAR(100),
    Back NVARCHAR(100)
);
GO

-- Resources Section
CREATE TABLE ResourcesSections (
    Id INT PRIMARY KEY IDENTITY(1,1),
    Language NVARCHAR(10),
    CardName NVARCHAR(100),
    CardDescription NVARCHAR(255),
    BackgroundImg NVARCHAR(255)
);
GO

CREATE TABLE ResourcesCards (
    Id INT PRIMARY KEY IDENTITY(1,1),
    ResourcesSectionId INT FOREIGN KEY REFERENCES ResourcesSections(Id),
    CardName NVARCHAR(100),
    CardDescription NVARCHAR(255),
    CardButton NVARCHAR(100),
    CardSvg NVARCHAR(MAX)
);
GO

